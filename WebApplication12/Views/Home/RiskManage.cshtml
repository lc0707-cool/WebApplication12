@{
    ViewData["Title"] = "資安風險定義維護";
}

<div class="container mt-4">

    <div class="jumbotron p-4 p-md-5 text-white rounded bg-dark shadow">
        <div class="col-md-12 px-0">
            <h1 class="display-5 font-italic">資安風險維護控制台</h1>
            <p class="lead my-3">
                本模組用於管理與維護企業資安風險定義，新增之風險項目將同步更新至風險評估作業系統。
            </p>
        </div>
    </div>

    <div class="row mt-4">

        <div class="col-md-5">
            <div class="card p-4 shadow-sm border-warning h-100">

                <h5 class="text-warning fw-bold mb-3">新增風險定義</h5>

                <p class="text-muted small">
                    請輸入欲新增之資安風險名稱。
                </p>

                <form action="/Home/AddCustomRisk" method="post" class="mt-2">
                    <div class="mb-3">
                        <label class="form-label fw-bold">風險名稱</label>
                        <input type="text"
                               name="newRiskName"
                               class="form-control"
                               placeholder="例如：AI 數據偏誤與幻覺風險"
                               required />
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold shadow-sm">
                        寫入資料庫
                    </button>
                </form>

                @if (TempData["Result"] != null)
                {
                    <div class="alert alert-success mt-3 small shadow-sm" role="alert">
                        @TempData["Result"]
                    </div>
                }

            </div>
        </div>

        <div class="col-md-7">
            <div class="card p-4 shadow-sm border-secondary h-100">

                <h5 class="text-secondary fw-bold mb-3">目前已啟用之風險項目</h5>

                <table class="table table-striped table-hover align-middle mt-2">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width: 30%">風險代碼</th>
                            <th style="width: 70%">風險名稱</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in ViewBag.RiskDictionary)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-dark px-3 py-2">
                                        @item.Key
                                    </span>
                                </td>
                                <td class="fw-bold text-muted">
                                    @item.Value
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>

    </div>
</div>