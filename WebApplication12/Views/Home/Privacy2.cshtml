<form asp-action="AddItem" method="post">
    <div class="mb-3">
        <label class="form-label fw-bold">1. 請輸入評估項目/對象名稱：</label>
        <input type="text" name="AddProduct" class="form-control" placeholder="例如：防火牆主機、***檔案" required />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">2. 請選擇項目類型：</label>
        <select name="AddAssetType" class="form-select">
            <option value="硬體設備">硬體設備</option>
            <option value="雲端服務">雲端服務</option>
            <option value="行動裝置">行動裝置</option>
            <option value="軟體組件">軟體組件</option>
            <option value="未分類" selected>未分類</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">確認</button>
</form>