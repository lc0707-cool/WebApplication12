@model IEnumerable<WebApplication12.Models.Product>

@{
    ViewData["Title"] = "基層作業管理工作台";
}

<div class="container mt-4">
    <h2>🛠️ 基層作業管理工作台 (產品清單 + 風險評估)</h2>
    <p class="text-success">@TempData["Result"]</p>

    <div class="mb-3 w-50">
        <div class="input-group">
            <span class="input-group-text">🔍 快速搜尋</span>
            <input type="text" id="searchInput" class="form-control" placeholder="輸入產品名稱或風險搜尋..." />
        </div>
    </div>

    <table class="table table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>編號</th>
                <th>產品名稱</th>
                <th>目前資安風險狀態</th>
                <th>管理操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var X in Model)
            {
                <tr id="row-@X.Id">
                    <td>@X.Id</td>
                    <td class="product-name">@X.Item</td>
                    <td><span class="badge bg-info text-dark" id="badge-@X.Id">@X.Risk</span></td>
                    <td>
                        <button type="button" class="btn btn-outline-primary btn-sm me-2" onclick="openRiskPanel(@X.Id, '@X.Item')">⚙️ 調整風險</button>
                        <button type="button" class="btn btn-warning btn-sm" onclick="moveToTrash(@X.Id)">🗑️ 刪除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="card p-4 shadow mt-4 border-primary" id="workPanel" style="display:none;">
        <h5 class="text-primary">正在即時評估：<span id="lblCurrentProduct" class="fw-bold"></span> (ID: <span id="lblId"></span>)</h5>
        <hr />
        <label class="form-label fw-bold">請勾選此資產面臨的資安風險 (可多選)：</label>
        <div class="my-3 p-3 border rounded bg-light">
            @foreach (var item in ViewBag.RiskDictionary)
            {
                if (item.Key != "X0")
                {
                    <div class="form-check form-check-inline me-4 mb-2">
                        <input class="form-check-input risk-checkbox" type="checkbox" value="@item.Key" id="chk-@item.Key">
                        <label class="form-check-label" for="chk-@item.Key">
                            <span class="badge bg-secondary">@item.Key</span> @item.Value
                        </label>
                    </div>
                }
            }
        </div>
        <div>
            <button class="btn btn-success px-4" id="btnSubmit">儲存並即時更新</button>
            <button class="btn btn-light border ms-2" onclick="$('#workPanel').fadeOut();">取消</button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
    // 即時搜尋過濾
    $("#searchInput").on("keyup", function () {
    var value = $(this).val().toLowerCase();
    $("table tbody tr").filter(function () {
    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
    });
    });

    // 提交更新風險
    $("#btnSubmit").click(function () {
    var id = $("#lblId").text();
    var selectedRisks = [];

    $(".risk-checkbox:checked").each(function () {
    selectedRisks.push($(this).val());
    });

    var riskString = selectedRisks.length > 0 ? selectedRisks.join(';') : "X0";

    $.ajax({
    url: '/Home/UpdateRiskAjax',
    type: 'POST',
    data: { id: id, risk: riskString },
    success: function (response) {
    alert(response);
    // 終極高光時刻：不重新整理網頁，直接即時去撈取新的中文翻譯並更新列表上的 Badge！
    location.reload(); // 重新載入刷新狀態
    }
    });
    });
    });

    // 點擊「調整風險」按鈕觸發
    function openRiskPanel(id, itemName) {
    $("#lblId").text(id);
    $("#lblCurrentProduct").text(itemName);
    $(".risk-checkbox").prop('checked', false);

    // 用 Ajax 去後台撈出這筆產品目前的原始 X1;X2 代碼，並自動幫 Checkbox 打勾
    $.ajax({
    url: '/Home/GetRiskAjax',
    type: 'GET',
    data: { id: id },
    success: function (dbRisk) {
    if (dbRisk && dbRisk !== "X0") {
    var risks = dbRisk.split(';');
    risks.forEach(function (riskCode) {
    $("#chk-" + riskCode.trim()).prop('checked', true);
    });
    }
    $("#workPanel").fadeIn();
    $('html, body').animate({ scrollTop: $("#workPanel").offset().top }, 500); // 畫面平滑滾動到作業區
    }
    });
    }

    // 軟刪除
    function moveToTrash(id) {
    if (confirm("確定要將此品項移至資源回收桶嗎？")) {
    $.ajax({
    url: '/Home/SoftDeleteAjax',
    type: 'POST',
    data: { id: id },
    success: function (response) {
    alert(response);
    $("#row-" + id).fadeOut(500);
    $("#workPanel").hide();
    }
    });
    }
    }
</script>